{
  "version": "2.0.0",
  // Run tasks in an interactive bash shell so that ~/.bashrc is sourced.
  // This ensures tools installed via nvm (~/.nvm) or uv (~/.local/bin)
  // are on the PATH — non-interactive shells skip .bashrc and miss them.
  "options": {
    "shell": {
      "executable": "/bin/bash",
      "args": ["-i", "-c"]
    }
  },
  "tasks": [
    {
      "label": "Backend: start",
      "type": "shell",
      "command": "uv run uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload",
      "options": {
        "cwd": "${workspaceFolder}/pyapp"
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "Frontend: start",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/client"
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      // Ctrl+Shift+B to start both servers in parallel
      "label": "Dev: start all",
      "dependsOn": ["Backend: start", "Frontend: start"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
