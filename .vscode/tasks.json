{
  "version": "2.0.0",
  // Run tasks in an interactive bash shell so that ~/.bashrc is sourced.
  // This ensures tools installed via nvm (~/.nvm) or uv (~/.local/bin)
  // are on the PATH — non-interactive shells skip .bashrc and miss them.
  "options": {
    "shell": {
      "executable": "/bin/bash",
      "args": [
        "-i",
        "-c"
      ]
    }
  },
  "tasks": [
    {
      "label": "Backend: start",
      "type": "shell",
      "command": "uv run uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload",
      "options": {
        "cwd": "${workspaceFolder}/pyapp"
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "Frontend: start",
      "type": "shell",
      "command": "npm run dev",
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}/client"
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      },
      // Tell VSCode when this long-running task is "ready" so preLaunchTask
      // doesn't wait forever. Matches Vite's startup output:
      //   VITE v6.x  ready in xxx ms
      //   ➜  Local:   http://localhost:5173/
      "problemMatcher": [
        {
          "owner": "vite",
          "pattern": [{ "regexp": "^NOMATCH$" }],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "VITE",
            "endsPattern": "Local:"
          }
        }
      ]
    },
    {
      // Ctrl+Shift+B to start both servers in parallel
      "label": "Dev: start all",
      "dependsOn": [
        "Backend: start",
        "Frontend: start"
      ],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}