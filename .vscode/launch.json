{
  "version": "0.2.0",
  "configurations": [
    {
      // Debug the FastAPI backend with auto-reload
      // Run 'uv sync' at the repo root first so the .venv exists
      "name": "FastAPI (debug)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--host", "0.0.0.0",
        "--port", "8000",
        "--reload"
      ],
      // IMPORTANT: cwd must be pyapp/ for 'app.main:app' module resolution
      "cwd": "${workspaceFolder}/pyapp",
      "python": "${workspaceFolder}/.venv/bin/python",
      "justMyCode": true
    },
    {
      // Debug the frontend using VSCode's built-in browser (no extension needed).
      // Requires the Vite dev server to already be running on :5173.
      "name": "Browser (debug frontend)",
      "type": "editor-browser",
      "request": "launch",
      "url": "http://localhost:5173"
    }
  ],
  // Compound launches — pick one from the Run & Debug dropdown (or F5)
  "compounds": [
    {
      // Backend debugger + Vite frontend task
      "name": "Full stack (debug)",
      "configurations": ["FastAPI (debug)"],
      "preLaunchTask": "Frontend: start",
      "stopAll": true
    },
    {
      // Both backend and frontend debuggers + Vite task
      "name": "Full stack (debug both)",
      "configurations": ["FastAPI (debug)", "Browser (debug frontend)"],
      "preLaunchTask": "Frontend: start",
      "stopAll": true
    }
  ]
}
